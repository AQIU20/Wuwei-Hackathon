{
  "name": "unforce-make-server",
  "version": "0.1.0",
  "description": "Cloud agent server for Unforce Make, with coding tools and live hardware access.",
  "scripts": {
    "dev": "bun --watch src/main/index.ts",
    "build": "next build",
    "bridge": "bun run scripts/hardware-bridge.ts",
    "mqtt:test:hello": "bun run scripts/mqtt-hello-publisher.ts",
    "mqtt:test:railway": "bun run scripts/test-mqtt-railway-ingest.ts",
    "hardware-events:test:write": "bun run scripts/test-hardware-events-write.ts",
    "start": "bun src/main/index.ts",
    "test": "bun test",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck": "bun run typecheck:node",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write ."
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.88",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/react": "^3.0.148",
    "@electron-toolkit/utils": "^4.0.0",
    "@mariozechner/pi-ai": "0.64.0",
    "@mariozechner/pi-coding-agent": "0.64.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sinclair/typebox": "^0.34.48",
    "@tavily/core": "^0.7.2",
    "ai": "^6.0.146",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "hono": "^4.12.12",
    "mqtt": "^5.15.1",
    "next": "16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-highlight": "^7.0.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "bun-types": "^1.3.11",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
